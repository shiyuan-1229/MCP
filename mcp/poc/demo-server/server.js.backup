  { id: "pr01", title: "元气森林系列 买2箱9折", desc: "全场元气森林气泡水买2箱享9折优惠", valid: "本月" },
  { id: "pr02", title: "鲜牛奶 第二件半价", desc: "指定鲜牛奶第二件半价", valid: "本月" },
  { id: "pr03", title: "面包组合 ¥9.9 特惠", desc: "精选面包组合限时特价", valid: "本周" },
  { id: "pr04", title: "会员双倍积分", desc: "全场购物享双倍会员积分", valid: "本月" },
  { id: "pr05", title: "新用户首单8折", desc: "首次下单立享8折优惠", valid: "长期" },
];

const INVENTORY = {
  "元气森林海盐菠萝": { store1: 32, store2: 18, store3: 24 },
  "元气森林白桃": { store1: 18, store2: 15, store3: 20 },
  "农夫山泉5L": { store1: 24, store2: 30, store3: 16 },
  "农夫山泉550ml": { store1: 48, store2: 60, store3: 42 },
  "鲜牛奶": { store1: 15, store2: 12, store3: 9 },
  "面包组合": { store1: 12, store2: 8, store3: 14 },
  "薯片大礼包": { store1: 9, store2: 6, store3: 11 },
  "可乐330ml": { store1: 60, store2: 55, store3: 48 },
  "雪碧330ml": { store1: 55, store2: 50, store3: 42 },
  "方便面": { store1: 30, store2: 35, store3: 28 },
  "三明治": { store1: 7, store2: 5, store3: 8 },
