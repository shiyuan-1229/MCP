      ["chk_25", "doc_member_day", "col_promo_rules", "会员日每月 8 日，会员享双倍积分和专属折扣。", "会员日,双倍积分,折扣"],
      ["chk_26", "doc_member_day", "col_promo_rules", "会员生日当月可领取生日券，有效期 30 天。", "生日券,有效期,领取"],
      ["chk_27", "doc_member_day", "col_promo_rules", "会员权益以系统等级为准，不同等级折扣和积分倍率不同。", "等级,折扣,积分"]
    ];

    const insertCustomer = db.prepare("INSERT OR IGNORE INTO platform_customers (id,name,industry,contact,tier,status) VALUES (?,?,?,?,?,?)"); customers.forEach(row => insertCustomer.run(...row));
    const insertProject = db.prepare("INSERT OR IGNORE INTO platform_projects (id,customer_id,name,stage,owner,progress,due_date) VALUES (?,?,?,?,?,?,?)"); projects.forEach(row => insertProject.run(...row));
    const insertSource = db.prepare("INSERT OR IGNORE INTO platform_data_sources (id,project_id,name,type,auth_mode,status) VALUES (?,?,?,?,?,?)"); sources.forEach(row => insertSource.run(...row));
    const insertAsset = db.prepare("INSERT OR IGNORE INTO platform_mcp_assets (id,project_id,name,capability,status,version,endpoint,owner,tools) VALUES (?,?,?,?,?,?,?,?,?)"); assets.forEach(row => insertAsset.run(row[0], row[1], row[2], row[3], row[4], row[5], row[6], row[7], encode(row[8])));
    const insertPolicy = db.prepare("INSERT OR IGNORE INTO platform_gateway_policies (id,project_id,name,auth_mode,authorization_scope,rate_limit,masking_rules,audit_enabled,status) VALUES (?,?,?,?,?,?,?,?,?)"); policies.forEach(row => insertPolicy.run(...row));
    const insertRelease = db.prepare("INSERT OR IGNORE INTO platform_mcp_releases (id,asset_id,version,status,tested_at,released_at,notes) VALUES (?,?,?,?,?,?,?)"); releases.forEach(row => insertRelease.run(...row));
    const insertDeliverable = db.prepare("INSERT OR IGNORE INTO platform_deliverables (id,project_id,name,type,status) VALUES (?,?,?,?,?)"); deliverables.forEach(row => insertDeliverable.run(...row));
    const insertBill = db.prepare("INSERT OR IGNORE INTO platform_billing_records (id,customer_id,item,period,amount,status,calls) VALUES (?,?,?,?,?,?,?)"); bills.forEach(row => insertBill.run(...row));
    const insertKbCollection = db.prepare("INSERT OR IGNORE INTO kb_collections (id,name,description,doc_count,chunk_count,status) VALUES (?,?,?,?,?,?)"); kbCollections.forEach(row => insertKbCollection.run(...row));
    const insertKbDocument = db.prepare("INSERT OR IGNORE INTO kb_documents (id,collection_id,title,source_url,chunk_count,status) VALUES (?,?,?,?,?,?)"); kbDocuments.forEach(row => insertKbDocument.run(...row));
    const insertKbChunk = db.prepare("INSERT OR IGNORE INTO kb_chunks (id,document_id,collection_id,content,keywords) VALUES (?,?,?,?,?)"); kbChunks.forEach(row => insertKbChunk.run(...row));
    const insertAccess = db.prepare("INSERT OR IGNORE INTO platform_access_configs (id,customer_id,project_id,name,type,endpoint,api_key,scope,status) VALUES (?,?,?,?,?,?,?,?,?)"); accessConfigs.forEach(row => insertAccess.run(...row));
    const insertEvent = db.prepare("INSERT INTO platform_call_events (id,asset_id,caller,status,latency_ms,business_result,trace_id,created_at) VALUES (?,?,?,?,?,?,?,datetime('now', ?))");
    if (count("platform_call_events") === 0) {
      for (let i = 0; i < 80; i += 1) {
        const assetId = assets[i % assets.length][0];
        const ok = i % 13 !== 0;
        insertEvent.run(makeId("evt"), assetId, ["WeCom", "Service Agent", "Ops Dashboard", "OA Bot"][i % 4], ok ? "success" : "error", 80 + (i * 17) % 420, ok ? ["coupon", "redeem", "query", "conversion"][i % 4] : "argument_error", `trace_${10000 + i}`, `-${i % 28} days`);
      }
    }
    const insertUser = db.prepare("INSERT OR IGNORE INTO platform_users (id,username,password_hash,role,display_name,customer_id) VALUES (?,?,?,?,?,?)");
    insertUser.run("usr_admin", "admin", hashPassword("admin123"), "admin", "科传管理员", "");
    insertUser.run("usr_retail", "meijia", hashPassword("store123"), "customer", "美佳零售集团", "cust_retail");
    insertUser.run("usr_hzm", "hzm", hashPassword("123456"), "customer", "华智制造", "cust_manufacturing");
    insertUser.run("usr_xrf", "xrf", hashPassword("123456"), "customer", "鑫融金服", "cust_finance");
    insertUser.run("usr_ahwy", "ahwy", hashPassword("123456"), "customer", "安和物业", "cust_property");
    insertUser.run("usr_zxjy", "zxjy", hashPassword("123456"), "customer", "知行教育", "cust_education");
  });
  tx();
}
seed();

function currentSession(req) {
  const header = req.headers.authorization || "";
  const token = header.startsWith("Bearer ") ? header.slice(7) : "";
  if (!token) return null;
  return db.prepare(`SELECT s.token, u.id, u.username, u.role, u.display_name, u.customer_id FROM platform_sessions s JOIN platform_users u ON u.id = s.user_id WHERE s.token = ? AND datetime(s.expires_at) > datetime('now')`).get(token);
}
function requireAuth(req, res, next) { const session = currentSession(req); if (!session) return res.status(401).json({ error: "session expired" }); req.user = session; next(); }
function requireAdmin(req, res, next) { if (req.user?.role !== "admin") return res.status(403).json({ error: "admin role required" }); next(); }
function customerScope(req) { return req.user.role === "admin" ? null : req.user.customer_id; }
function scopedProjects(req) { const cid = customerScope(req); const sql = "SELECT p.*, c.name AS customer_name FROM platform_projects p JOIN platform_customers c ON c.id = p.customer_id" + (cid ? " WHERE p.customer_id = ?" : "") + " ORDER BY p.due_date"; return cid ? db.prepare(sql).all(cid) : db.prepare(sql).all(); }
function scopedAssets(req) { const cid = customerScope(req); const sql = "SELECT a.*, p.name AS project_name, c.name AS customer_name FROM platform_mcp_assets a JOIN platform_projects p ON p.id = a.project_id JOIN platform_customers c ON c.id = p.customer_id" + (cid ? " WHERE p.customer_id = ?" : "") + " ORDER BY a.status = 'published' DESC, a.created_at DESC"; return cid ? db.prepare(sql).all(cid) : db.prepare(sql).all(); }
function callStats(ids) { if (!ids.length) return { total: 0, successRate: 0, avgLatency: 0, errorCount: 0 }; const ph = ids.map(() => "?").join(","); const row = db.prepare(`SELECT COUNT(*) AS total, SUM(CASE WHEN status='success' THEN 1 ELSE 0 END) AS success, AVG(latency_ms) AS avg_latency, SUM(CASE WHEN status!='success' THEN 1 ELSE 0 END) AS errors FROM platform_call_events WHERE asset_id IN (${ph})`).get(...ids); return { total: row.total || 0, successRate: row.total ? Math.round((row.success || 0) * 1000 / row.total) / 10 : 0, avgLatency: Math.round(row.avg_latency || 0), errorCount: row.errors || 0 }; }

app.post("/auth/login", (req, res) => { const { username, password } = req.body || {}; const user = db.prepare("SELECT * FROM platform_users WHERE username = ?").get(username); if (!user || !verifyPassword(password, user.password_hash)) return res.status(401).json({ error: "invalid username or password" }); const token = crypto.randomBytes(24).toString("hex"); db.prepare("INSERT INTO platform_sessions (token,user_id,expires_at) VALUES (?,?,datetime('now','+12 hours'))").run(token, user.id); res.json({ token, user: { id: user.id, username: user.username, role: user.role, display_name: user.display_name, customer_id: user.customer_id } }); });
app.post("/auth/logout", requireAuth, (req, res) => { db.prepare("DELETE FROM platform_sessions WHERE token = ?").run(req.user.token); res.json({ ok: true }); });
app.get("/auth/me", requireAuth, (req, res) => res.json({ id: req.user.id, username: req.user.username, role: req.user.role, display_name: req.user.display_name, customer_id: req.user.customer_id }));
app.get("/health", (req, res) => res.json({ status: "ok", service: "mcp-forge-admin", uptime: Math.round(process.uptime()), assets: count("platform_mcp_assets"), projects: count("platform_projects") }));
app.get("/api/platform/summary", requireAuth, (req, res) => { const projects = scopedProjects(req); const assets = scopedAssets(req); const stats = callStats(assets.map(a => a.id)); const published = assets.filter(a => a.status === "published").length; const cid = customerScope(req); const billing = cid ? db.prepare("SELECT COALESCE(SUM(amount),0) AS amount FROM platform_billing_records WHERE customer_id = ?").get(cid) : db.prepare("SELECT COALESCE(SUM(amount),0) AS amount FROM platform_billing_records").get(); res.json({ customers: cid ? 1 : count("platform_customers"), projects: projects.length, assets: assets.length, published, calls: stats.total, successRate: stats.successRate, avgLatency: stats.avgLatency, errors: stats.errorCount, billingAmount: Math.round((billing.amount || 0) * 100) / 100 }); });
app.get("/api/platform/customers", requireAuth, (req, res) => { const cid = customerScope(req); res.json(cid ? db.prepare("SELECT * FROM platform_customers WHERE id = ?").all(cid) : db.prepare("SELECT * FROM platform_customers ORDER BY created_at DESC").all()); });
app.get("/api/platform/projects", requireAuth, (req, res) => res.json(scopedProjects(req)));
app.get("/api/platform/data-sources", requireAuth, (req, res) => { const ids = scopedProjects(req).map(p => p.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT ds.*, p.name AS project_name FROM platform_data_sources ds JOIN platform_projects p ON p.id = ds.project_id WHERE ds.project_id IN (${ids.map(() => "?").join(",")}) ORDER BY ds.status, ds.name`).all(...ids)); });
app.get("/api/platform/mcp-assets", requireAuth, (req, res) => res.json(scopedAssets(req).map(a => ({ ...a, tools: decode(a.tools) }))));
app.post("/api/platform/mcp-assets", requireAuth, requireAdmin, (req, res) => { const { project_id, name, capability, owner, tools } = req.body || {}; if (!project_id || !name || !capability) return res.status(400).json({ error: "project_id, name and capability are required" }); const asset = { id: makeId("mcp"), project_id, name, capability, status: "draft", version: "v0.1.0", endpoint: `/mcp/${name}`, owner: owner || "Delivery", tools: tools || [name] }; db.prepare("INSERT INTO platform_mcp_assets (id,project_id,name,capability,status,version,endpoint,owner,tools) VALUES (?,?,?,?,?,?,?,?,?)").run(asset.id, asset.project_id, asset.name, asset.capability, asset.status, asset.version, asset.endpoint, asset.owner, encode(asset.tools)); res.status(201).json(asset); });
app.get("/api/platform/releases", requireAuth, (req, res) => { const ids = scopedAssets(req).map(a => a.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT r.*, a.name AS asset_name FROM platform_mcp_releases r JOIN platform_mcp_assets a ON a.id = r.asset_id WHERE r.asset_id IN (${ids.map(() => "?").join(",")}) ORDER BY COALESCE(r.released_at, r.tested_at) DESC`).all(...ids)); });
app.get("/api/platform/gateway-policies", requireAuth, (req, res) => { const ids = scopedProjects(req).map(p => p.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT gp.*, p.name AS project_name FROM platform_gateway_policies gp JOIN platform_projects p ON p.id = gp.project_id WHERE gp.project_id IN (${ids.map(() => "?").join(",")}) ORDER BY gp.status DESC`).all(...ids)); });
app.get("/api/platform/call-events", requireAuth, (req, res) => { const ids = scopedAssets(req).map(a => a.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT ce.*, a.name AS asset_name FROM platform_call_events ce JOIN platform_mcp_assets a ON a.id = ce.asset_id WHERE ce.asset_id IN (${ids.map(() => "?").join(",")}) ORDER BY ce.created_at DESC LIMIT 80`).all(...ids)); });
app.get("/api/platform/deliverables", requireAuth, (req, res) => { const ids = scopedProjects(req).map(p => p.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT d.*, p.name AS project_name FROM platform_deliverables d JOIN platform_projects p ON p.id = d.project_id WHERE d.project_id IN (${ids.map(() => "?").join(",")}) ORDER BY d.updated_at DESC`).all(...ids)); });
app.get("/api/platform/billing", requireAuth, (req, res) => { const cid = customerScope(req); const sql = "SELECT br.*, c.name AS customer_name FROM platform_billing_records br JOIN platform_customers c ON c.id = br.customer_id" + (cid ? " WHERE br.customer_id = ?" : "") + " ORDER BY br.period DESC, br.item"; res.json(cid ? db.prepare(sql).all(cid) : db.prepare(sql).all()); });
app.get("/api/platform/access-configs", requireAuth, (req, res) => { const cid = customerScope(req); const sql = "SELECT ac.*, c.name AS customer_name, p.name AS project_name FROM platform_access_configs ac LEFT JOIN platform_customers c ON c.id = ac.customer_id LEFT JOIN platform_projects p ON p.id = ac.project_id" + (cid ? " WHERE ac.customer_id = ?" : "") + " ORDER BY ac.status DESC, ac.type"; res.json(cid ? db.prepare(sql).all(cid) : db.prepare(sql).all()); });
app.get("/api/platform/kb/collections", requireAuth, (req, res) => { res.json(db.prepare("SELECT * FROM kb_collections ORDER BY created_at DESC").all()); });
app.get("/api/platform/kb/documents", requireAuth, (req, res) => { const { collection_id } = req.query || {}; const sql = collection_id ? "SELECT * FROM kb_documents WHERE collection_id = ? ORDER BY title" : "SELECT * FROM kb_documents ORDER BY title"; res.json(collection_id ? db.prepare(sql).all(collection_id) : db.prepare(sql).all()); });
app.get("/api/platform/kb/search", requireAuth, (req, res) => { const { q = "" } = req.query || {}; if (!q.trim()) return res.json({ query: q, results: [] }); const query = q.trim().toLowerCase(); const chunks = db.prepare("SELECT kc.*, kd.title AS document_title, kc2.name AS collection_name FROM kb_chunks kc JOIN kb_documents kd ON kd.id = kc.document_id JOIN kb_collections kc2 ON kc2.id = kc.collection_id").all(); const results = chunks.map(c => { const keywords = decode(c.keywords); const content = c.content.toLowerCase(); let score = 0; if (content.includes(query)) score += 3; if (keywords.some(k => k.toLowerCase().includes(query))) score += 5; if (query.split(/\s+/).some(term => content.includes(term))) score += 1; return { ...c, score }; }).filter(c => c.score > 0).sort((a, b) => b.score - a.score).slice(0, 5); res.json({ query: q, results: results.map(r => ({ document_title: r.document_title, collection_name: r.collection_name, content: r.content, keywords: decode(r.keywords), score: r.score })) }); });
app.get("/api/tools", requireAuth, (req, res) => res.json(scopedAssets(req).map(a => ({ name: a.name, description: a.capability, status: a.status, tools: decode(a.tools) }))));
app.post("/admin/simulate-call", requireAuth, (req, res) => { const { tool_name, arguments: args = {} } = req.body || {}; const traceId = `trace_${crypto.randomBytes(4).toString("hex")}`; const asset = db.prepare("SELECT * FROM platform_mcp_assets WHERE name = ?").get(tool_name) || db.prepare("SELECT * FROM platform_mcp_assets LIMIT 1").get(); if (!asset) return res.status(404).json({ error: "no MCP asset available" }); let result; if (tool_name === "sales_top_products") { const topN = Math.min(Math.max(Number(args.top_n) || 10, 1), 20); result = { tool: tool_name, trace_id: traceId, range: args.date_range || "month", rows: Array.from({ length: topN }).map((_, i) => ({ rank: i + 1, product: ["Milk", "Coffee", "Yogurt", "Water", "Sandwich", "Energy Drink", "Fruit Cup", "Bread", "Tea", "Lunch Box"][i % 10], revenue: 9800 - i * 520, quantity: 420 - i * 19, contribution: `${(18 - i * 0.9).toFixed(1)}%` })) }; } else if (tool_name === "member_expiring_benefits") { result = { tool: tool_name, trace_id: traceId, member: args.member_id || "M10001", name: "Demo Member", current_points: 2350, expiring_points: 320, points_expire_at: "2026-07-31", coupons: ["8 off over 50", "second coffee half price"], expiring_coupons: ["fresh food 15% off"], suggested_action: "remind member to redeem expiring benefits" }; } else { result = { tool: tool_name || "kb_search", trace_id: traceId, answer: "Sandbox call completed with authorization and masking checks." }; } db.prepare("INSERT INTO platform_call_events (id,asset_id,caller,status,latency_ms,business_result,trace_id) VALUES (?,?,?,?,?,?,?)").run(makeId("evt"), asset.id, req.user.display_name, "success", 120 + Math.floor(Math.random() * 180), tool_name || "simulate", traceId); res.json(result); });

app.get("/admin/login-bg.png", (req, res) => res.sendFile(path.join(ADMIN_DIR, "login-bg.png")));
app.get("/admin/brand-icon.png", (req, res) => res.sendFile(path.join(ADMIN_DIR, "brand-icon.png")));

// 禁止浏览器缓存 admin 静态资源，避免演示时修改不生效
app.use("/admin", (req, res, next) => {
  res.setHeader("Cache-Control", "no-store, no-cache, must-revalidate, proxy-revalidate");
  res.setHeader("Pragma", "no-cache");
  res.setHeader("Expires", "0");
  next();
});

app.use("/admin/assets", express.static(path.join(ADMIN_DIR, "assets")));
app.get("/admin", (req, res) => res.sendFile(path.join(ADMIN_DIR, "index.html")));
app.get("/", (req, res) => res.redirect("/admin"));
if (fs.existsSync(CLIENT_DIR)) app.use(express.static(CLIENT_DIR));
app.listen(PORT, () => console.log(`MCP Forge admin server running at http://localhost:${PORT}/admin`));
