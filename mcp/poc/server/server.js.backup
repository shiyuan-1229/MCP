import express from "express";
import path from "path";
import { fileURLToPath } from "url";
import crypto from "crypto";
import fs from "fs";
import Database from "better-sqlite3";

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const app = express();
const PORT = Number(process.env.PORT || process.env.SERVER_PORT || 3100);
const DB_PATH = process.env.DB_PATH || path.join(__dirname, "..", "mcp_forge.db");
const db = new Database(DB_PATH);
const ADMIN_DIR = path.join(__dirname, "..", "admin");
const CLIENT_DIR = path.join(__dirname, "..", "client");

db.pragma("journal_mode = WAL");
db.pragma("foreign_keys = ON");
app.use(express.json({ limit: "2mb" }));

function makeId(prefix) { return `${prefix}_${crypto.randomBytes(5).toString("hex")}`; }
function hashPassword(password, salt = crypto.randomBytes(12).toString("hex")) {
  const hash = crypto.pbkdf2Sync(String(password), salt, 120000, 32, "sha256").toString("hex");
  return `${salt}:${hash}`;
}
function verifyPassword(password, stored) {
  if (!stored || !stored.includes(":")) return false;
  const [salt] = stored.split(":");
  return hashPassword(password, salt) === stored;
}
function encode(value) { return JSON.stringify(value || []); }
function decode(value) { try { return value ? JSON.parse(value) : []; } catch { return []; } }
function count(table) { return db.prepare(`SELECT COUNT(*) AS c FROM ${table}`).get().c; }

db.exec(`
  CREATE TABLE IF NOT EXISTS platform_users (
    id TEXT PRIMARY KEY,
    username TEXT UNIQUE NOT NULL,
    password_hash TEXT NOT NULL,
    role TEXT NOT NULL CHECK(role IN ('admin','customer')),
    display_name TEXT NOT NULL,
    customer_id TEXT DEFAULT '',
    created_at TEXT DEFAULT CURRENT_TIMESTAMP
  );
  CREATE TABLE IF NOT EXISTS platform_sessions (
    token TEXT PRIMARY KEY,
    user_id TEXT NOT NULL,
    created_at TEXT DEFAULT CURRENT_TIMESTAMP,
    expires_at TEXT NOT NULL,
    FOREIGN KEY(user_id) REFERENCES platform_users(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_customers (
    id TEXT PRIMARY KEY,
    name TEXT NOT NULL,
    industry TEXT NOT NULL,
    contact TEXT,
    tier TEXT DEFAULT 'Pro',
    status TEXT DEFAULT 'delivery',
    created_at TEXT DEFAULT CURRENT_TIMESTAMP
  );
  CREATE TABLE IF NOT EXISTS platform_projects (
    id TEXT PRIMARY KEY,
    customer_id TEXT NOT NULL,
    name TEXT NOT NULL,
    stage TEXT DEFAULT 'testing',
    owner TEXT,
    progress INTEGER DEFAULT 50,
    due_date TEXT,
    FOREIGN KEY(customer_id) REFERENCES platform_customers(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_data_sources (
    id TEXT PRIMARY KEY,
    project_id TEXT NOT NULL,
    name TEXT NOT NULL,
    type TEXT NOT NULL,
    auth_mode TEXT DEFAULT 'API Key',
    status TEXT DEFAULT 'connected',
    last_checked TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(project_id) REFERENCES platform_projects(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_mcp_assets (
    id TEXT PRIMARY KEY,
    project_id TEXT NOT NULL,
    name TEXT NOT NULL,
    capability TEXT NOT NULL,
    status TEXT DEFAULT 'testing',
    version TEXT DEFAULT 'v1.0.0',
    endpoint TEXT,
    owner TEXT,
    tools TEXT DEFAULT '[]',
    created_at TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(project_id) REFERENCES platform_projects(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_mcp_releases (
    id TEXT PRIMARY KEY,
    asset_id TEXT NOT NULL,
    version TEXT NOT NULL,
    status TEXT DEFAULT 'pending',
    tested_at TEXT,
    released_at TEXT,
    notes TEXT,
    FOREIGN KEY(asset_id) REFERENCES platform_mcp_assets(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_gateway_policies (
    id TEXT PRIMARY KEY,
    project_id TEXT NOT NULL,
    name TEXT NOT NULL,
    auth_mode TEXT NOT NULL,
    authorization_scope TEXT NOT NULL,
    rate_limit TEXT NOT NULL,
    masking_rules TEXT NOT NULL,
    audit_enabled INTEGER DEFAULT 1,
    status TEXT DEFAULT 'enabled',
    FOREIGN KEY(project_id) REFERENCES platform_projects(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_call_events (
    id TEXT PRIMARY KEY,
    asset_id TEXT NOT NULL,
    caller TEXT NOT NULL,
    status TEXT NOT NULL,
    latency_ms INTEGER NOT NULL,
    business_result TEXT,
    trace_id TEXT NOT NULL,
    created_at TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(asset_id) REFERENCES platform_mcp_assets(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_deliverables (
    id TEXT PRIMARY KEY,
    project_id TEXT NOT NULL,
    name TEXT NOT NULL,
    type TEXT NOT NULL,
    status TEXT DEFAULT 'ready',
    updated_at TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(project_id) REFERENCES platform_projects(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_billing_records (
    id TEXT PRIMARY KEY,
    customer_id TEXT NOT NULL,
    item TEXT NOT NULL,
    period TEXT NOT NULL,
    amount REAL NOT NULL,
    status TEXT DEFAULT 'pending',
    calls INTEGER DEFAULT 0,
    FOREIGN KEY(customer_id) REFERENCES platform_customers(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS platform_access_configs (
    id TEXT PRIMARY KEY,
    customer_id TEXT NOT NULL,
    project_id TEXT,
    name TEXT NOT NULL,
    type TEXT NOT NULL,
    endpoint TEXT,
    api_key TEXT,
    scope TEXT,
    status TEXT DEFAULT 'enabled',
    created_at TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(customer_id) REFERENCES platform_customers(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS kb_collections (
    id TEXT PRIMARY KEY,
    name TEXT NOT NULL,
    description TEXT,
    doc_count INTEGER DEFAULT 0,
    chunk_count INTEGER DEFAULT 0,
    status TEXT DEFAULT 'active',
    created_at TEXT DEFAULT CURRENT_TIMESTAMP
  );
  CREATE TABLE IF NOT EXISTS kb_documents (
    id TEXT PRIMARY KEY,
    collection_id TEXT NOT NULL,
    title TEXT NOT NULL,
    source_url TEXT,
    chunk_count INTEGER DEFAULT 0,
    status TEXT DEFAULT 'indexed',
    created_at TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY(collection_id) REFERENCES kb_collections(id) ON DELETE CASCADE
  );
  CREATE TABLE IF NOT EXISTS kb_chunks (
    id TEXT PRIMARY KEY,
    document_id TEXT NOT NULL,
    collection_id TEXT NOT NULL,
    content TEXT NOT NULL,
    keywords TEXT DEFAULT '[]',
    FOREIGN KEY(document_id) REFERENCES kb_documents(id) ON DELETE CASCADE
  );
`);

