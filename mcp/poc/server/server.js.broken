ustomer_id,name,stage,owner,progress,due_date) VALUES (",",",",",",?)"); projects.forEach(row => insertProject.run(...row));    const insertSource = db.prepare("INSERT OR IGNORE INTO platform_data_sources (id,project_id,name,type,auth_mode,status) VALUES (",",",",",?)"); sources.forEach(row => insertSource.run(...row));    const insertAsset = db.prepare("INSERT OR IGNORE INTO platform_mcp_assets (id,project_id,name,capability,status,version,endpoint,owner,tools) VALUES (",",",",",",",",?)"); assets.forEach(row => insertAsset.run(row[0], row[1], row[2], row[3], row[4], row[5], row[6], row[7], encode(row[8])));    const insertPolicy = db.prepare("INSERT OR IGNORE INTO platform_gateway_policies (id,project_id,name,auth_mode,authorization_scope,rate_limit,masking_rules,audit_enabled,status) VALUES (",",",",",",",",?)"); policies.forEach(row => insertPolicy.run(...row));    const insertRelease = db.prepare("INSERT OR IGNORE INTO platform_mcp_releases (id,asset_id,version,status,tested_at,released_at,notes) VALUES (",",",",",",?)"); releases.forEach(row => insertRelease.run(...row));    const insertDeliverable = db.prepare("INSERT OR IGNORE INTO platform_deliverables (id,project_id,name,type,status) VALUES (",",",",?)"); deliverables.forEach(row => insertDeliverable.run(...row));    const insertBill = db.prepare("INSERT OR IGNORE INTO platform_billing_records (id,customer_id,item,period,amount,status,calls) VALUES (",",",",",",?)"); bills.forEach(row => insertBill.run(...row));    const insertKbCollection = db.prepare("INSERT OR IGNORE INTO kb_collections (id,name,description,doc_count,chunk_count,status) VALUES (",",",",",?)"); kbCollections.forEach(row => insertKbCollection.run(...row));    const insertKbDocument = db.prepare("INSERT OR IGNORE INTO kb_documents (id,collection_id,title,source_url,chunk_count,status) VALUES (",",",",",?)"); kbDocuments.forEach(row => insertKbDocument.run(...row));    const insertKbChunk = db.prepare("INSERT OR IGNORE INTO kb_chunks (id,document_id,collection_id,content,keywords) VALUES (",",",",?)"); kbChunks.forEach(row => insertKbChunk.run(...row));    const insertAccess = db.prepare("INSERT OR IGNORE INTO platform_access_configs (id,customer_id,project_id,name,type,endpoint,api_key,scope,status,environment,certificate,credential_expires_at,credential_last_rotated_at,webhook_url,description) VALUES (",",",",",",",",",",",",",",?)"); accessConfigs.forEach(row => insertAccess.run(...row));    // 鎺ュ叆鍋ュ悍妫€鏌?seed    const insertHealth = db.prepare("INSERT INTO platform_access_health_checks (id,access_id,status,latency_ms,status_code,auth_ok,error_message,detail,checked_by,checked_at) VALUES (",",",",",",",",",datetime('now', ?))");    if (count("platform_access_health_checks") === 0) {      const healthSeed = [        ["acc_retail_api", "ok", 82, 200, 1, null, 0],        ["acc_retail_api", "ok", 96, 200, 1, null, -2],        ["acc_retail_api", "error", 0, 503, 0, "璇佷功鍗冲皢杩囨湡", -5],        ["acc_manufacturing_oauth", "ok", 134, 200, 1, null, 0],        ["acc_manufacturing_oauth", "ok", 121, 200, 1, null, -1],        ["acc_manufacturing_oauth", "ok", 109, 200, 1, null, -3],        ["acc_finance_mtls", "ok", 79, 200, 1, null, 0],        ["acc_finance_mtls", "ok", 88, 200, 1, null, -1],        ["acc_property_wechat", "ok", 156, 200, 1, null, 0],        ["acc_property_wechat", "ok", 178, 200, 1, null, -2],        ["acc_property_wechat", "error", 0, 401, 0, "Token 宸插け鏁", -4],        ["acc_education_dingtalk", "ok", 112, 200, 1, null, 0],        ["acc_education_dingtalk", "ok", 124, 200, 1, null, -1]      ];      healthSeed.forEach(([accId, status, lat, code, auth, err, dayOffset], i) => {        const traceId = `trace_hc_${1000 + i}`;        const detail = JSON.stringify({ trace_id: traceId, http_version: "HTTP/1.1" });        insertHealth.run(makeId("hc"), accId, status, lat, code, auth, err, detail, "绉戜紶绠＄悊鍛", `${dayOffset} days`);      });      // 鏇存柊 platform_access_configs 鐨勬渶杩戝仴搴风姸鎬?      db.prepare("UP