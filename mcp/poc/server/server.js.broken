", -20],        ["acc_manufacturing_oauth", "api_key", "***old", "***rotated", "绉戜紶绠＄悊鍛", -22],        ["acc_manufacturing_oauth", "scope", "宸ュ崟鏁版嵁", "宸ュ崟銆佽川妫€鏁版嵁", "绉戜紶绠＄悊鍛", -18],        ["acc_finance_mtls", "certificate", "sha256:oldcert...", "sha256:abc123def456...", "绉戜紶绠＄悊鍛", -35],        ["acc_finance_mtls", "api_key_rotated", "***", "***", "绉戜紶绠＄悊鍛", -15],        ["acc_property_wechat", "webhook_url", "https://work.weixin.qq.com/old", "https://work.weixin.qq.com/...", "绉戜紶绠＄悊鍛", -10],        ["acc_education_dingtalk", "endpoint", "https://oapi.dingtalk.com/old", "https://oapi.dingtalk.com/...", "绉戜紶绠＄悊鍛", -8],        ["acc_education_dingtalk", "environment", "sandbox", "production", "绉戜紶绠＄悊鍛", -5]      ];      auditSeed.forEach(([accId, field, oldV, newV, who, dayOffset], i) => {        insertAudit.run(makeId("aa"), accId, field, oldV, newV, who, `${dayOffset} days`);      });    }    // Webhook 鍥炶皟鏃ュ織 seed    const insertWebhook = db.prepare("INSERT INTO platform_access_webhook_logs (id,access_id,event_type,url,status,status_code,response_body,error_message,retry_count,created_at,last_retry_at) VALUES (",",",",",",",",",datetime('now', ?),datetime('now', ?))");    if (count("platform_access_webhook_logs") === 0) {      const webhookSeed = [        ["acc_property_wechat", "ticket.created", "https://work.weixin.qq.com/callback/property", "success", 200, "{\"errcode\":0,\"errmsg\":\"ok\"}", null, 0, 0, 0],        ["acc_property_wechat", "ticket.assigned", "https://work.weixin.qq.com/callback/property", "success", 200, "{\"errcode\":0,\"errmsg\":\"ok\"}", null, 0, -1, -1],        ["acc_property_wechat", "ticket.resolved", "https://work.weixin.qq.com/callback/property", "failed", 500, null, "鐩爣鏈嶅姟杩斿洖 500 Internal Server Error", 2, -2, -2],        ["acc_education_dingtalk", "course.reminder", "https://oapi.dingtalk.com/callback/edu", "success", 200, "{\"errcode\":0,\"errmsg\":\"ok\"}", null, 0, 0, 0],        ["acc_education_dingtalk", "course.reminder", "https://oapi.dingtalk.com/callback/edu", "success", 200, "{\"errcode\":0,\"errmsg\":\"ok\"}", null, 0, -1, -1],        ["acc_education_dingtalk", "notice.broadcast", "https://oapi.dingtalk.com/callback/edu", "retrying", 502, null, "Bad Gateway, 鑷姩閲嶈瘯涓", 1, -3, -3],        ["acc_retail_api", "member.coupon", "https://hooks.mcpforge.local/retail/callback", "success", 200, "{\"received\":true}", null, 0, 0, 0],        ["acc_retail_api", "store.daily.report", "https://hooks.mcpforge.local/retail/callback", "failed", 404, null, "Webhook URL 宸插け鏁堬紝闇€鏇存柊", 3, -4, -4]      ];      webhookSeed.forEach(([accId, event, url, status, code, payload, err, retry, dayOffset, lastRetry], i) => {        insertWebhook.run(makeId("wh"), accId, event, url, status, code, payload, err, retry, `${dayOffset} days`, `${lastRetry} days`);      });      db.prepare("UPDATE platform_access_configs SET webhook_last_success_at = datetime('now') WHERE id = ?").run("acc_property_wechat");      db.prepare("UPDATE platform_access_configs SET webhook_last_success_at = datetime('now') WHERE id = ?").run("acc_education_dingtalk");      db.prepare("UPDATE platform_access_configs SET webhook_last_success_at = datetime('now') WHERE id = ?").run("acc_retail_api");    }    const insertEvent = db.prepare("INSERT INTO platform_call_events (id,asset_id,caller,status,latency_ms,business_result,trace_id,created_at) VALUES (",",",",",",",datetime('now', ?))");    if (count("platform_call_events") === 0) {      for (let i = 0; i < 80; i += 1) {        const assetId = assets[i % assets.length][0];        const ok = i % 13 !== 0;        insertEvent.run(makeId("evt"), assetId, ["WeCom", "Service Agent", "Ops Dashboard", "OA Bot"][i % 4], ok ? "success" : "error", 80 + (i * 17) % 420, ok ? ["coupon", "redeem", "query", "conversion"][i % 4] : "argument_error", `trace_${10000 + i}`, `-${i % 28} days`);      }    }    const insertUser = db.prepare("INSERT OR IGNORE INTO platform_users (id,username,password_hash,role,display_name,customer_id) VALUES (",",",",",?)");    insertUser.run("usr_admin", "admin", hashPassword("admin123"), "admin", "绉戜紶绠＄悊鍛", "");    insertUser.run("usr_retail", "meijia", hashPassword("store123"), "customer", "缇庝匠闆跺敭闆嗗洟", "cust_retail");    insertUser.run("usr_hzm", "hzm", hashPassword("123456"), "customer", "鍗庢櫤鍒堕"\n, "cust_manufacturing");    insertUser.run("usr_xrf", "xrf", hashPassword("123456"), "customer", "閼瀺閲戞湇", "cust_finance");    insertUser.run("usr_ahwy", "ahwy", hashPassword("123456"), "customer", "瀹夊拰鐗╀笟", "cust_property");    insertUser.run("usr_zxjy", "zxjy", hashPassword("123456"), "customer", "鐭ヨ鏁欒偛", "cust_education");  });  tx();}// 鍏煎浣庣増鏈?SQLite 鐨勫畨鍏ㄦ坊鍔犲垪function addColumnIfNotExists(table, column, def) {  const cols = db.prepare(`PRAGMA table_info(${table})`).all().map(c => c.name);  if (!cols.includes(column)) {    db.exec(`ALTER TABLE ${table} ADD COLUMN ${column} ${def}`);  }}// 鏁版嵁搴撶増鏈縼绉?function runMigrations() {  // 娓呯悊澶辫触鐨勮縼绉诲皾璇曪紙娌℃湁 DISABLE 鏍囧織鐨勩€佸凡閮ㄥ垎搴旂敤鐨勶級  db.exec("DELETE FROM schema_migrations WHERE version IN (1,2,3,4,5)");  // 鍚屾椂娓呯悊鏃ц縼绉?SQL 涓彲鑳藉凡娣诲姞鍒楀甫鏉ョ殑閲嶅 KEY 閿欒锛汣REATE TABLE 鐢?IF NOT EXISTS 瀹夊叏銆?  const migrations = [    { version: 1, name: 'initial schema', sql: '' },    { version: 2, name: 'add gateway_policy masking_rules and audit', action: () => {      addColumnIfNotExists('platform_gateway_policies', 'masking_rules', 'TEXT');      addColumnIfNotExists('platform_gateway_policies', 'audit_enabled', 'INTEGER DEFAULT 1');    }},    { version: 3, name: 'add gateway_policy changed_by and changed_at', action: () => {      addColumnIfNotExists('platform_gateway_policies', 'changed_by', 'TEXT');      addColumnIfNotExists('platform_gateway_policies', 'changed_at', 'TEXT');    }},    { version: 4, name: 'add project description', action: () => {      addColumnIfNotExists('platform_projects', 'description', 'TEXT');    }},    { version: 5, name: 'add asset updated_at', action: () => {      addColumnIfNotExists('platform_mcp_assets', 'updated_at', 'TEXT');    }},    { version: 6, name: 'add policy changes audit table', sql: `      CREATE TABLE IF NOT EXISTS platform_policy_changes (        id TEXT PRIMARY KEY,        policy_id TEXT NOT NULL,        field TEXT NOT NULL,        old_value TEXT,        new_value TEXT,        changed_by TEXT NOT NULL,        changed_at TEXT DEFAULT CURRENT_TIMESTAMP,        FOREIGN KEY(policy_id) REFERENCES platform_gateway_policies(id) ON DELETE CASCADE      );    ` },    { version: 7, name: 'access configs: env, cert, health, credential lifecycle, webhook, audit', action: () => {      addColumnIfNotExists('platform_access_configs', 'environment', 'TEXT DEFAULT "production"');      addColumnIfNotExists('platform_access_configs', 'certificate', 'TEXT');      addColumnIfNotExists('platform_access_configs', 'last_health_check_at', 'TEXT');      addColumnIfNotExists('platform_access_configs', 'last_health_status', 'TEXT');      addColumnIfNotExists('platform_access_configs', 'last_health_detail', 'TEXT');      addColumnIfNotExists('platform_access_configs', 'credential_expires_at', 'TEXT');      addColumnIfNotExists('platform_access_configs', 'credential_last_rotated_at', 'TEXT');      addColumnIfNotExists('platform_access_configs', 'webhook_url', 'TEXT');      addColumnIfNotExists('platform_access_configs', 'webhook_last_success_at', 'TEXT');      addColumnIfNotExists('platform_access_configs', 'description', 'TEXT');    }, sql: `      CREATE TABLE IF NOT EXISTS platform_access_health_checks (        id TEXT PRIMARY KEY,        access_id TEXT NOT NULL,        checked_at TEXT DEFAULT CURRENT_TIMESTAMP,        status TEXT NOT NULL,        latency_ms INTEGER,        status_code INTEGER,        auth_ok INTEGER DEFAULT 0,        error_message TEXT,        detail TEXT,        checked_by TEXT,        FOREIGN KEY(access_id) REFERENCES platform_access_configs(id) ON DELETE CASCADE      );      CREATE TABLE IF NOT EXISTS platform_access_credentials (        id TEXT PRIMARY KEY,        access_id TEXT NOT NULL,        type TEXT NOT NULL,        value_hash TEXT NOT NULL,        expires_at TEXT,        rotated_at TEXT DEFAULT CURRENT_TIMESTAMP,        rotated_by TEXT,        status TEXT DEFAULT 'active',        FOREIGN KEY(access_id) REFERENCES platform_access_configs(id) ON DELETE CASCADE      );      CREATE TABLE IF NOT EXISTS platform_access_webhook_logs (        id TEXT PRIMARY KEY,        access_id TEXT NOT NULL,        event_type TEXT NOT NULL,        url TEXT NOT NULL,        status TEXT NOT NULL,        status_code INTEGER,        request_body TEXT,        response_body TEXT,        error_message TEXT,        retry_count INTEGER DEFAULT 0,        created_at TEXT DEFAULT CURRENT_TIMESTAMP,        last_retry_at TEXT,        FOREIGN KEY(access_id) REFERENCES platform_access_configs(id) ON DELETE CASCADE      );      CREATE TABLE IF NOT EXISTS platform_access_audit (        id TEXT PRIMARY KEY,        access_id TEXT NOT NULL,        field TEXT NOT NULL,        old_value TEXT,        new_value TEXT,        changed_by TEXT NOT NULL,        changed_at TEXT DEFAULT CURRENT_TIMESTAMP,        FOREIGN KEY(access_id) REFERENCES platform_access_configs(id) ON DELETE CASCADE      );    ` }  ];  // 妫€鏌ュ凡搴旂敤鐨勮縼绉?  const applied = db.prepare('SELECT version FROM schema_migrations').all().map(r => r.version);  const pending = migrations.filter(m => !applied.includes(m.version));  if (pending.length === 0) {    console.log('All migrations already applied');    return;  }  console.log(`Applying ${pending.length} pending migrations...`);  const tx = db.transaction(() => {    pending.forEach(m => {      if (m.sql && m.sql.trim()) {        db.exec(m.sql);      }      if (m.action) {        m.action();      }      db.prepare('INSERT INTO schema_migrations (version, name) VALUES (", ?)').run(m.version, m.name);      console.log(`  Applied migration ${m.version}: ${m.name}`);    });  });  tx();  console.log('Migrations completed');}try {  seed();  console.log('seed completed successfully');  runMigrations();} catch (e) {  console.error('ERROR during seed/migration:', e.message);  console.error('stack:', e.stack);  throw e;}function currentSession(req) {  const header = req.headers.authorization || "";  const token = header.startsWith("Bearer ") ? header.slice(7) : "";  if (!token) return null;  return db.prepare(`SELECT s.token, u.id, u.username, u.role, u.display_name, u.customer_id FROM platform_sessions s JOIN platform_users u ON u.id = s.user_id WHERE s.token = ? AND datetime(s.expires_at) > datetime('now')`).get(token);}function requireAuth(req, res, next) { const session = currentSession(req); if (!session) return res.status(401).json({ error: "session expired" }); req.user = session; next(); }function requireAdmin(req, res, next) { if (req.user?.role !== "admin") return res.status(403).json({ error: "admin role required" }); next(); }function customerScope(req) { return req.user.role === "admin" ? null : req.user.customer_id; }function scopedProjects(req) { const cid = customerScope(req); const sql = "SELECT p.*, c.name AS customer_name FROM platform_projects p JOIN platform_customers c ON c.id = p.customer_id" + (cid ? " WHERE p.customer_id = ?" : "") + " ORDER BY p.due_date"; return cid ? db.prepare(sql).all(cid) : db.prepare(sql).all(); }function scopedProjectById(req, id) { const cid = customerScope(req); const sql = "SELECT p.*, c.name AS customer_name FROM platform_projects p JOIN platform_customers c ON c.id = p.customer_id WHERE p.id = ?" + (cid ? " AND p.customer_id = ?" : ""); return cid ? db.prepare(sql).get(id, cid) : db.prepare(sql).get(id); }function scopedAssets(req) { const cid = customerScope(req); const sql = "SELECT a.*, p.name AS project_name, c.name AS customer_name FROM platform_mcp_assets a JOIN platform_projects p ON p.id = a.project_id JOIN platform_customers c ON c.id = p.customer_id" + (cid ? " WHERE p.customer_id = ?" : "") + " ORDER BY a.status = 'published' DESC, a.created_at DESC"; return cid ? db.prepare(sql).all(cid) : db.prepare(sql).all(); }function callStats(ids) { if (!ids.length) return { total: 0, successRate: 0, avgLatency: 0, errorCount: 0 }; const ph = ids.map(() => "?").join(","); const row = db.prepare(`SELECT COUNT(*) AS total, SUM(CASE WHEN status='success' THEN 1 ELSE 0 END) AS success, AVG(latency_ms) AS avg_latency, SUM(CASE WHEN status!='success' THEN 1 ELSE 0 END) AS errors FROM platform_call_events WHERE asset_id IN (${ph})`).get(...ids); return { total: row.total || 0, successRate: row.total ? Math.round((row.success || 0) * 1000 / row.total) / 10 : 0, avgLatency: Math.round(row.avg_latency || 0), errorCount: row.errors || 0 }; }app.post("/auth/login", (req, res) => { const { username, password } = req.body || {}; const user = db.prepare("SELECT * FROM platform_users WHERE username = ?").get(username); if (!user || !verifyPassword(password, user.password_hash)) return res.status(401).json({ error: "invalid username or password" }); const token = crypto.randomBytes(24).toString("hex"); db.prepare("INSERT INTO platform_sessions (token,user_id,expires_at) VALUES (",",datetime('now','+12 hours'))").run(token, user.id); res.json({ token, user: { id: user.id, username: user.username, role: user.role, display_name: user.display_name, customer_id: user.customer_id } }); });app.post("/auth/logout", requireAuth, (req, res) => { db.prepare("DELETE FROM platform_sessions WHERE token = ?").run(req.user.token); res.json({ ok: true }); });app.get("/auth/me", requireAuth, (req, res) => res.json({ id: req.user.id, username: req.user.username, role: req.user.role, display_name: req.user.display_name, customer_id: req.user.customer_id }));app.get("/health", (req, res) => res.json({ status: "ok", service: "mcp-forge-admin", uptime: Math.round(process.uptime()), assets: count("platform_mcp_assets"), projects: count("platform_projects") }));app.get("/api/platform/summary", requireAuth, (req, res) => { const projects = scopedProjects(req); const assets = scopedAssets(req); const stats = callStats(assets.map(a => a.id)); const published = assets.filter(a => a.status === "published").length; const cid = customerScope(req); const billing = cid ? db.prepare("SELECT COALESCE(SUM(amount),0) AS amount FROM platform_billing_records WHERE customer_id = ?").get(cid) : db.prepare("SELECT COALESCE(SUM(amount),0) AS amount FROM platform_billing_records").get(); res.json({ customers: cid ? 1 : count("platform_customers"), projects: projects.length, assets: assets.length, published, calls: stats.total, successRate: stats.successRate, avgLatency: stats.avgLatency, errors: stats.errorCount, billingAmount: Math.round((billing.amount || 0) * 100) / 100 }); });app.get("/api/platform/customers", requireAuth, (req, res) => { const cid = customerScope(req); res.json(cid ? db.prepare("SELECT * FROM platform_customers WHERE id = ?").all(cid) : db.prepare("SELECT * FROM platform_customers ORDER BY created_at DESC").all()); });app.get("/api/platform/projects", requireAuth, (req, res) => res.json(scopedProjects(req)));app.get("/api/platform/projects/:id", requireAuth, (req, res) => {  const project = scopedProjectById(req, req.params.id);  if (!project) return res.status(404).json({ error: "project not found" });  const assets = db.prepare("SELECT * FROM platform_mcp_assets WHERE project_id = ? ORDER BY status = 'published' DESC, created_at DESC").all(project.id).map(a => ({ ...a, tools: decode(a.tools) }));  const assetIds = assets.map(a => a.id);  const releases = assetIds.length ? db.prepare(`SELECT r.*, a.name AS asset_name FROM platform_mcp_releases r JOIN platform_mcp_assets a ON a.id = r.asset_id WHERE r.asset_id IN (${assetIds.map(() => "?").join(",")}) ORDER BY COALESCE(r.released_at, r.tested_at) DESC`).all(...assetIds) : [];  const access = db.prepare("SELECT ac.*, c.name AS customer_name, p.name AS project_name FROM platform_access_configs ac LEFT JOIN platform_customers c ON c.id = ac.customer_id LEFT JOIN platform_projects p ON p.id = ac.project_id WHERE ac.project_id = ? ORDER BY ac.status DESC, ac.type").all(project.id);  const billing = db.prepare("SELECT br.*, c.name AS customer_name FROM platform_billing_records br JOIN platform_customers c ON c.id = br.customer_id WHERE br.customer_id = ? ORDER BY br.period DESC, br.item").all(project.customer_id);  const recentErrors = assetIds.length ? db.prepare(`SELECT ce.*, a.name AS asset_name FROM platform_call_events ce JOIN platform_mcp_assets a ON a.id = ce.asset_id WHERE ce.asset_id IN (${assetIds.map(() => "?").join(",")}) AND ce.status != 'success' ORDER BY ce.created_at DESC LIMIT 8`).all(...assetIds) : [];  res.json({ project, assets, access, releases, billing, recentErrors });});app.put("/api/platform/projects/:id", requireAuth, requireAdmin, (req, res) => {  const { id } = req.params;  const existing = db.prepare("SELECT * FROM platform_projects WHERE id = ?").get(id);  if (!existing) return res.status(404).json({ error: "project not found" });  const { owner, stage, due_date, description } = req.body || {};  const allowedStages = new Set(["published", "testing", "data-source", "draft"]);  if (stage !== undefined && !allowedStages.has(stage)) return res.status(400).json({ error: "invalid stage" });  if (due_date !== undefined && due_date && !/^\d{4}-\d{2}-\d{2}$/.test(due_date)) return res.status(400).json({ error: "invalid due_date" });  db.prepare("UPDATE platform_projects SET owner = COALESCE(", owner), stage = COALESCE(", stage), due_date = COALESCE(", due_date), description = COALESCE(", description) WHERE id = ?").run(owner || null, stage || null, due_date || null, description || null, id);  res.json(db.prepare("SELECT p.*, c.name AS customer_name FROM platform_projects p JOIN platform_customers c ON c.id = p.customer_id WHERE p.id = ?").get(id));});app.get("/api/platform/data-sources", requireAuth, (req, res) => { const ids = scopedProjects(req).map(p => p.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT ds.*, p.name AS project_name FROM platform_data_sources ds JOIN platform_projects p ON p.id = ds.project_id WHERE ds.project_id IN (${ids.map(() => "?").join(",")}) ORDER BY ds.status, ds.name`).all(...ids)); });app.get("/api/platform/mcp-assets", requireAuth, (req, res) => res.json(scopedAssets(req).map(a => ({ ...a, tools: decode(a.tools) }))));app.post("/api/platform/data-sources", requireAuth, requireAdmin, (req, res) => { const { project_id, name, type, auth_mode } = req.body || {}; if (!project_id || !name || !type) return res.status(400).json({ error: "project_id, name and type are required" }); if (!["REST API", "Database", "Knowledge Base", "Industry Template"].includes(type)) return res.status(400).json({ error: "type must be one of REST API / Database / Knowledge Base / Industry Template" }); const ds = { id: makeId("ds"), project_id, name, type, auth_mode: auth_mode || "API Key", status: "已接入" }; db.prepare("INSERT INTO platform_data_sources (id,project_id,name,type,auth_mode,status) VALUES (",",",",",?)").run(ds.id, ds.project_id, ds.name, ds.type, ds.auth_mode, ds.status); res.status(201).json(ds); });app.post("/api/platform/mcp-assets", requireAuth, requireAdmin, (req, res) => { const { project_id, name, capability, owner, tools } = req.body || {}; if (!project_id || !name || !capability) return res.status(400).json({ error: "project_id, name and capability are required" }); const asset = { id: makeId("mcp"), project_id, name, capability, status: "draft", version: "v0.1.0", endpoint: `/mcp/${name}`, owner: owner || "Delivery", tools: tools || [name] }; db.prepare("INSERT INTO platform_mcp_assets (id,project_id,name,capability,status,version,endpoint,owner,tools) VALUES (",",",",",",",",?)").run(asset.id, asset.project_id, asset.name, asset.capability, asset.status, asset.version, asset.endpoint, asset.owner, encode(asset.tools)); res.status(201).json(asset); });app.get("/api/platform/releases", requireAuth, (req, res) => { const ids = scopedAssets(req).map(a => a.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT r.*, a.name AS asset_name FROM platform_mcp_releases r JOIN platform_mcp_assets a ON a.id = r.asset_id WHERE r.asset_id IN (${ids.map(() => "?").join(",")}) ORDER BY COALESCE(r.released_at, r.tested_at) DESC`).all(...ids)); });app.get("/api/platform/gateway-policies", requireAuth, (req, res) => { const ids = scopedProjects(req).map(p => p.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT gp.*, p.name AS project_name FROM platform_gateway_policies gp JOIN platform_projects p ON p.id = gp.project_id WHERE gp.project_id IN (${ids.map(() => "?").join(",")}) ORDER BY gp.status DESC`).all(...ids)); });app.post("/api/platform/gateway-policies", requireAuth, requireAdmin, (req, res) => {  const { project_id, name, auth_mode, authorization_scope = "", rate_limit, masking_rules, status = "enabled", audit_enabled = 1 } = req.body || {};  if (!project_id || !name || !auth_mode || !rate_limit) return res.status(400).json({ error: "project_id, name, auth_mode and rate_limit are required" });  const policy = { id: makeId("pol"), project_id, name, auth_mode, authorization_scope, rate_limit, masking_rules: masking_rules || "[]", audit_enabled: audit_enabled ? 1 : 0, status, changed_by: req.user.display_name };  db.prepare("INSERT INTO platform_gateway_policies (id,project_id,name,auth_mode,authorization_scope,rate_limit,masking_rules,audit_enabled,status,changed_by) VALUES (",",",",",",",",",?)").run(policy.id, policy.project_id, policy.name, policy.auth_mode, policy.authorization_scope, policy.rate_limit, policy.masking_rules, policy.audit_enabled, policy.status, policy.changed_by);  // 璁板綍鍒涘缓鍙樻洿  const insChange = db.prepare("INSERT INTO platform_policy_changes (id,policy_id,field,old_value,new_value,changed_by) VALUES (",",",",",?)");  insChange.run(makeId("chg"), policy.id, "created", "", "绛栫暐鍒涘缓", req.user.display_name);  res.status(201).json(db.prepare("SELECT gp.*, p.name AS project_name FROM platform_gateway_policies gp JOIN platform_projects p ON p.id = gp.project_id WHERE gp.id = ?").get(policy.id));});app.put("/api/platform/gateway-policies/:id", requireAuth, requireAdmin, (req, res) => {  const { id } = req.params;  const { name, auth_mode, authorization_scope, rate_limit, masking_rules, status, audit_enabled } = req.body || {};  const existing = db.prepare("SELECT * FROM platform_gateway_policies WHERE id = ?").get(id);  if (!existing) return res.status(404).json({ error: "policy not found" });  // 璁板綍鍙樻洿鍓嶅揩鐓?  const changes = [];  if (name !== undefined && name !== existing.name) changes.push({ field: "name", old: existing.name, new: name });  if (auth_mode !== undefined && auth_mode !== existing.auth_mode) changes.push({ field: "auth_mode", old: existing.auth_mode, new: auth_mode });  if (authorization_scope !== undefined && authorization_scope !== existing.authorization_scope) changes.push({ field: "authorization_scope", old: existing.authorization_scope, new: authorization_scope });  if (rate_limit !== undefined && rate_limit !== existing.rate_limit) changes.push({ field: "rate_limit", old: existing.rate_limit, new: rate_limit });  if (masking_rules !== undefined && masking_rules !== existing.masking_rules) changes.push({ field: "masking_rules", old: existing.masking_rules, new: masking_rules });  if (status !== undefined && status !== existing.status) changes.push({ field: "status", old: existing.status, new: status });  if (audit_enabled !== undefined && Number(audit_enabled) !== existing.audit_enabled) changes.push({ field: "audit_enabled", old: String(existing.audit_enabled), new: String(audit_enabled ? 1 : 0) });  const sql = "UPDATE platform_gateway_policies SET name = COALESCE(", name), auth_mode = COALESCE(", auth_mode), authorization_scope = COALESCE(", authorization_scope), rate_limit = COALESCE(", rate_limit), masking_rules = COALESCE(", masking_rules), status = COALESCE(", status), audit_enabled = COALESCE(", audit_enabled), changed_by = ? WHERE id = ?";  db.prepare(sql).run(name || null, auth_mode || null, authorization_scope || null, rate_limit || null, masking_rules || null, status || null, (audit_enabled != null ? (audit_enabled ? 1 : 0) : null), req.user.display_name, id);  // 鍐欏叆鍙樻洿璁板綍  if (changes.length) {    const insChange = db.prepare("INSERT INTO platform_policy_changes (id,policy_id,field,old_value,new_value,changed_by) VALUES (",",",",",?)");    for (const c of changes) {      insChange.run(makeId("chg"), id, c.field, String(c.old || ""), String(c.new || ""), req.user.display_name);    }  }  res.json(db.prepare("SELECT gp.*, p.name AS project_name FROM platform_gateway_policies gp JOIN platform_projects p ON p.id = gp.project_id WHERE gp.id = ?").get(id));});app.delete("/api/platform/gateway-policies/:id", requireAuth, requireAdmin, (req, res) => {  const { id } = req.params;  const existing = db.prepare("SELECT * FROM platform_gateway_policies WHERE id = ?").get(id);  if (!existing) return res.status(404).json({ error: "policy not found" });  db.prepare("DELETE FROM platform_gateway_policies WHERE id = ?").run(id);  res.json({ ok: true, id });});app.get("/api/platform/policy-changes", requireAuth, (req, res) => {  const { policy_id } = req.query || {};  const ids = scopedProjects(req).map(p => p.id);  if (!ids.length) return res.json([]);  let sql, params;  if (policy_id) {    sql = `SELECT pc.* FROM platform_policy_changes pc JOIN platform_gateway_policies gp ON gp.id = pc.policy_id WHERE pc.policy_id = ? AND gp.project_id IN (${ids.map(() => "?").join(",")}) ORDER BY pc.changed_at DESC LIMIT 50`;    params = [policy_id, ...ids];  } else {    sql = `SELECT pc.* FROM platform_policy_changes pc JOIN platform_gateway_policies gp ON gp.id = pc.policy_id WHERE gp.project_id IN (${ids.map(() => "?").join(",")}) ORDER BY pc.changed_at DESC LIMIT 50`;    params = [...ids];  }  res.json(db.prepare(sql).all(...params));});app.get("/api/platform/call-events", requireAuth, (req, res) => {  const { page = "1", pageSize = "20", status, search } = req.query || {};  const ids = scopedAssets(req).map(a => a.id);  if (!ids.length) return res.json({ total: 0, page: Number(page), pageSize: Number(pageSize), data: [] });  let sql = `SELECT ce.*, a.name AS asset_name FROM platform_call_events ce JOIN platform_mcp_assets a ON a.id = ce.asset_id WHERE ce.asset_id IN (${ids.map(() => "?").join(",")})`;  const params = [...ids];  if (status) { sql += " AND ce.status = ?"; params.push(status); }  if (search) { sql += " AND (ce.caller LIKE ? OR ce.business_result LIKE ?)"; params.push(`%${search}%`); params.push(`%${search}%`); }  sql += " ORDER BY ce.created_at DESC";  const countResult = db.prepare("SELECT COUNT(*) AS total FROM (" + sql + ")").get(...params);  const total = countResult.total;  sql += " LIMIT ? OFFSET ?"; params.push(Number(pageSize)); params.push((Number(page) - 1) * Number(pageSize));  const data = db.prepare(sql).all(...params);  res.json({ total, page: Number(page), pageSize: Number(pageSize), data });});app.get("/api/platform/deliverables", requireAuth, (req, res) => { const ids = scopedProjects(req).map(p => p.id); if (!ids.length) return res.json([]); res.json(db.prepare(`SELECT d.*, p.name AS project_name FROM platform_deliverables d JOIN platform_projects p ON p.id = d.project_id WHERE d.project_id IN (${ids.map(() => "?").join(",")}) ORDER BY d.updated_at DESC`).all(...ids)); });app.get("/api/platform/access-configs", requireAuth, (req, res) => {  const cid = customerScope(req);  const sql = "SELECT ac.*, c.name AS customer_name, p.name AS project_name FROM platform_access_configs ac LEFT JOIN platform_customers c ON c.id = ac.customer_id LEFT JOIN platform_projects p ON p.id = ac.project_id" + (cid ? " WHERE ac.customer_id = ?" : "") + " ORDER BY ac.status DESC, ac.type";  res.json(cid ? db.prepare(sql).all(cid) : db.prepare(sql).all());});app.post("/api/platform/access-configs", requireAuth, requireAdmin, (req, res) => {  const { customer_id, project_id, name, type, endpoint, api_key, scope, environment = "production", webhook_url, description, certificate } = req.body || {};  if (!customer_id || !name || !type) return res.status(400).json({ error: "customer_id, name and type are required" });  const id = makeId("ac");  db.prepare("INSERT INTO platform_access_configs (id,customer_id,project_id,name,type,endpoint,api_key,scope,environment,webhook_url,description,certificate,status) VALUES (",",",",",",",",",",",",?)").run(id, customer_id, project_id || null, name, type, endpoint || null, api_key || null, scope || null, environment, webhook_url || null, description || null, certificate || null, "enabled");  // 璁板綍瀹¤  db.prepare("INSERT INTO platform_access_audit (id,access_id,field,old_value,new_value,changed_by) VALUES (",",",",",?)").run(makeId("aa"), id, "created", "", "鎺ュ叆閰嶇疆鍒涘缓", req.user.display_name);  res.status(201).json(db.prepare("SELECT ac.*, c.name AS customer_name, p.name AS project_name FROM platform_access_configs ac LEFT JOIN platform_customers c ON c.id = ac.customer_id LEFT JOIN platform_projects p ON p.id = ac.project_id WHERE ac.id = ?").get(id));});app.put("/api/platform/access-configs/:id", requireAuth, requireAdmin, (req, res) => {  const { id } = req.params;  const existing = db.prepare("SELECT * FROM platform_access_configs WHERE id = ?").get(id);  if (!existing) return res.status(404).json({ error: "access config not found" });  const { name, endpoint, api_key, scope, status, environment, webhook_url, description, certificate, project_id } = req.body || {};  // 璁板綍鍙樻洿  const changes = [];  if (name !== undefined && name !== existing.name) changes.push({ field: "name", old: existing.name, new: name });  if (endpoint !== undefined && endpoint !== existing.endpoint) changes.push({ field: "endpoint", old: existing.endpoint || "", new: endpoint || "" });  if (api_key !== undefined && api_key !== existing.api_key) changes.push({ field: "api_key", old: "***", new: "***" });  if (scope !== undefined && scope !== existing.scope) changes.push({ field: "scope", old: existing.scope || "", new: scope || "" });  if (status !== undefined && status !== existing.status) changes.push({ field: "status", old: existing.status, new: status });  if (environment !== undefined && environment !== existing.environment) changes.push({ field: "environment", old: existing.environment, new: environment });  if (webhook_url !== undefined && webhook_url !== existing.webhook_url) changes.push({ field: "webhook_url", old: existing.webhook_url || "", new: webhook_url || "" });  if (certificate !== undefined && certificate !== existing.certificate) changes.push({ field: "certificate", old: "***", new: "***" });  const sql = "UPDATE platform_access_configs SET name = COALESCE(",name), endpoint = COALESCE(",endpoint), api_key = COALESCE(",api_key), scope = COALESCE(",scope), status = COALESCE(",status), environment = COALESCE(",environment), webhook_url = COALESCE(",webhook_url), description = COALESCE(",description), certificate = COALESCE(",certificate), project_id = COALESCE(",project_id) WHERE id = ?";  db.prepare(sql).run(name || null, endpoint || null, api_key || null, scope || null, status || null, environment || null, webhook_url || null, description || null, certificate || null, project_id || null, id);  if (changes.length) {    const ins = db.prepare("INSERT INTO platform_access_audit (id,access_id,field,old_value,new_value,changed_by) VALUES (",",",",",?)");    for (const c of changes) ins.run(makeId("aa"), id, c.field, String(c.old), String(c.new), req.user.display_name);  }  res.json(db.prepare("SELECT ac.*, c.name AS customer_name, p.name AS project_name FROM platform_access_configs ac LEFT JOIN platform_customers c ON c.id = ac.customer_id LEFT JOIN platform_projects p ON p.id = ac.project_id WHERE ac.id = ?").get(id));});app.delete("/api/platform/access-configs/:id", requireAuth, requireAdmin, (req, res) => {  const { id } = req.params;  const existing = db.prepare("SELECT * FROM platform_access_configs WHERE id = ?").get(id);  if (!existing) return res.status(404).json({ error: "access config not found" });  db.prepare("DELETE FROM platform_access_configs WHERE id = ?").run(id);  res.json({ ok: true, id });});// 鎺ュ叆娴嬭瘯app.post("/api/platform/access-configs/:id/test", requireAuth, requireAdmin, (req, res) => {  const { id } = req.params;  const config = db.prepare("SELECT * FROM platform_access_configs WHERE id = ?").get(id);  if (!config) return res.status(404).json({ error: "access config not found" });  const traceId = `trace_${crypto.randomBytes(4).toString("hex")}`;  const start = Date.now();  // 妯℃嫙娴嬭瘯璇锋眰  let status = "ok", authOk = 1, statusCode = 200, latencyMs = 0, errorMsg = null;  try {    // 妯℃嫙缃戠粶寤惰繜    latencyMs = Math.floor(Math.random() * 150) + 30;    // 妯℃嫙鍙兘鐨勫け璐?    if (Math.random() < 0.1) { status = "error"; authOk = 0; statusCode = 401; errorMsg = "auth failed: invalid api_key"; }    else if (Math.random() < 0.05) { status = "error"; statusCode = 0; errorMsg = "connection timeout"; }  } catch (e) { status = "error"; statusCode = 0; errorMsg = e.message; }  latencyMs = Date.now() - start || latencyMs;  db.prepare("INSERT INTO platform_access_health_checks (id,access_id,status,latency_ms,status_code,auth_ok,error_message,detail,checked_by) VALUES (",",",",",",",",?)").run(makeId("hc"), id, status, latencyMs, statusCode, authOk, errorMsg, JSON.stringify({ trace_id: traceId }), req.user.display_name);  db.prepare("UPDATE platform_access_configs SET last_health_check_at = datetime('now'), last_health_status = ", last_health_detail = ? WHERE id = ?").run(status, JSON.stringify({ latency_ms: latencyMs, status_code: statusCode, auth_ok: authOk, trace_id: traceId }), id);  res.json({ status, latency_ms: latencyMs, status_code: statusCode, auth_ok: !!authOk, trace_id: traceId, error: errorMsg });});app.get("/api/platform/access-configs/:id/health", requireAuth, (req, res) => {  const { id } = req.params;  const config = db.prepare("SELECT * FROM platform_access_configs WHERE id = ?").get(id);  if (!config) return res.status(404).json({ error: "not found" });  const cid = customerScope(req);  if (cid && config.customer_id !== cid) return res.status(403).json({ error: "forbidden" });  res.json(db.prepare("SELECT * FROM platform_access_health_checks WHERE access_id = ? ORDER BY checked_at DESC LIMIT 20").all(id));});app.get("/api/platform/access-configs/:id/audit", requireAuth, (req, res) => {  const { id } = req.params;  const config = db.prepare("SELECT * FROM platform_access_configs WHERE id = ?").get(id);  if (!config) return res.status(404).json({ error: "not found" });  const cid = customerScope(req);  if (cid && config.customer_id !== cid) return res.status(403).json({ error: "forbidden" });  res.json(db.prepare("SELECT * FROM platform_access_audit WHERE access_id = ? ORDER BY changed_at DESC LIMIT 50").all(id));});app.get("/api/platform/access-configs/:id/webhook-logs", requireAuth, (req, res) => {  const { id } = req.params;  const config = db.prepare("SELECT * FROM platform_access_configs WHERE id = ?").get(id);  if (!config) return res.status(404).json({ error: "not found" });  const cid = customerScope(req);  if (cid && config.customer_id !== cid) return res.status(403).json({ error: "forbidden" });  res.json(db.prepare("SELECT * FROM platform_access_webhook_logs WHERE access_id = ? ORDER BY created_at DESC LIMIT 20").all(id));});app.get("/api/platform/access-configs/health-summary", requireAuth, (req, res) => {  const cid = customerScope(req);  const where = cid ? "WHERE ac.customer_id = ?" : "";  const params = cid ? [cid] : [];  const rows = db.prepare(`SELECT ac.id, ac.name, ac.last_health_status, ac.last_health_check_at, ac.last_health_detail, ac.customer_id FROM platform_access_configs ac ${where}`).all(...params);  res.json(rows.map(r => ({    ...r,    last_health_detail: r.last_health_detail ? safeParse(r.last_health_detail) : null  })));});app.get("/api/platform/access-configs/audit-summary", requireAuth, (req, res) => {  const cid = customerScope(req);  const sql = `SELECT a.id, a.access_id, a.field, a.old_value, a.new_value, a.changed_by, a.changed_at FROM platform_access_audit a JOIN platform_access_configs ac ON ac.id = a.access_id ${cid ? "WHERE ac.customer_id = ?" : ""} ORDER BY a.changed_at DESC LIMIT 100`;  res.json(db.prepare(sql).all(...(cid ? [cid] : [])));});app.get("/api/platform/access-configs/webhook-summary", requireAuth, (req, res) => {  const cid = customerScope(req);  const sql = `SELECT w.id, w.access_id, w.event_type, w.url, w.status, w.status_code, w.retry_count, w.error_message, w.created_at FROM platform_access_webhook_logs w JOIN platform_access_configs ac ON ac.id = w.access_id ${cid ? "WHERE ac.customer_id = ?" : ""} ORDER BY w.created_at DESC LIMIT 100`;  res.json(db.prepare(sql).all(...(cid ? [cid] : [])));});app.post("/api/platform/access-configs/:id/rotate-key", requireAuth, requireAdmin, (req, res) => {  const { id } = req.params;  const config = db.prepare("SELECT * FROM platform_access_configs WHERE id = ?").get(id);  if (!config) return res.status(404).json({ error: "access config not found" });  const newKey = `sk_${crypto.randomBytes(16).toString("hex")}`;  db.prepare("UPDATE platform_access_configs SET api_key = ? WHERE id = ?").run(newKey, id);  db.prepare("INSERT INTO platform_access_audit (id,access_id,field,old_value,new_value,changed_by) VALUES (",",",",",?)").run(makeId("aa"), id, "api_key_rotated", "***", "***", req.user.display_name);  db.prepare("UPDATE platform_access_configs SET credential_last_rotated_at = datetime('now') WHERE id = ?").run(id);  res.json({ ok: true, new_key: newKey });});app.get("/api/platform/kb/collections", requireAuth, (req, res) => {  res.json(db.prepare("SELECT * FROM kb_collections ORDER BY created_at DESC").all());});app.get("/api/platform/kb/documents", requireAuth, (req, res) => {  const { collection_id } = req.query || {};  const sql = collection_id ? "SELECT * FROM kb_documents WHERE collection_id = ? ORDER BY title" : "SELECT * FROM kb_documents ORDER BY title";  res.json(collection_id ? db.prepare(sql).all(collection_id) : db.prepare(sql).all());});app.get("/api/platform/kb/search", requireAuth, (req, res) => {  const { q = "" } = req.query || {};  if (!q.trim()) return res.json({ query: q, results: [] });  const query = q.trim().toLowerCase();  const chunks = db.prepare("SELECT kc.*, kd.title AS document_title, kc2.name AS collection_name FROM kb_chunks kc JOIN kb_documents kd ON kd.id = kc.document_id JOIN kb_collections kc2 ON kc2.id = kc.collection_id").all();  const results = chunks.map(c => {    const keywords = decode(c.keywords);    const content = c.content.toLowerCase();    let score = 0;    if (content.includes(query)) score += 3;    if (keywords.some(k => k.toLowerCase().includes(query))) score += 5;    if (query.split(/\s+/).some(term => content.includes(term))) score += 1;    return { ...c, score };  }).filter(c => c.score > 0).sort((a, b) => b.score - a.score).slice(0, 5);  res.json({ query: q, results: results.map(r => ({    document_title: r.document_title, collection_name: r.collection_name,    content: r.content, keywords: decode(r.keywords), score: r.score  })) });});app.get("/api/platform/billing", requireAuth, (req, res) => {  const cid = customerScope(req);  const sql = "SELECT br.*, c.name AS customer_name FROM platform_billing_records br JOIN platform_customers c ON c.id = br.customer_id" + (cid ? " WHERE br.customer_id = ?" : "") + " ORDER BY br.period DESC, br.item";  res.json(cid ? db.prepare(sql).all(cid) : db.prepare(sql).all());});app.get("/api/tools", requireAuth, (req, res) => res.json(scopedAssets(req).map(a => ({  name: a.name, description: a.capability, status: a.status, tools: decode(a.tools)}))));app.post("/admin/simulate-call", requireAuth, (req, res) => {  const { tool_name, arguments: args = {} } = req.body || {};  const traceId = `trace_${crypto.randomBytes(4).toString("hex")}`;  const asset = db.prepare("SELECT * FROM platform_mcp_assets WHERE name = ?").get(tool_name) || db.prepare("SELECT * FROM platform_mcp_assets LIMIT 1").get();  if (!asset) return res.status(404).json({ error: "no MCP asset available" });  let result;  if (tool_name === "sales_top_products") {    const topN = Math.min(Math.max(Number(args.top_n) || 10, 1), 20);    result = {      tool: tool_name, trace_id: traceId, range: args.date_range || "month",      rows: Array.from({ length: topN }).map((_, i) => ({        rank: i + 1,        product: ["Milk", "Coffee", "Yogurt", "Water", "Sandwich", "Energy Drink", "Fruit Cup", "Bread", "Tea", "Lunch Box"][i % 10],        revenue: 9800 - i * 520, quantity: 420 - i * 19,        contribution: `${(18 - i * 0.9).toFixed(1)}%`      }))    };  } else if (tool_name === "member_expiring_benefits") {    result = {      tool: tool_name, trace_id: traceId, member: args.member_id || "M10001",      name: "Demo Member", current_points: 2350, expiring_points: 320,      points_expire_at: "2026-07-31", coupons: ["8 off over 50", "second coffee half price"],      expiring_coupons: ["fresh food 15% off"], suggested_action: "remind member to redeem expiring benefits"    };  } else {    result = { tool: tool_name || "kb_search", trace_id: traceId, answer: "Sandbox call completed with authorization and masking checks." };  }  db.prepare("INSERT INTO platform_call_events (id,asset_id,caller,status,latency_ms,business_result,trace_id) VALUES (",",",",",",?)")    .run(makeId("evt"), asset.id, req.user.display_name, "success", 120 + Math.floor(Math.random() * 180), tool_name || "simulate", traceId);  res.json(result);});app.get("/admin/login-bg.png", (req, res) => res.sendFile(path.join(ADMIN_DIR, "login-bg.png")));app.get("/admin/brand-icon.png", (req, res) => res.sendFile(path.join(ADMIN_DIR, "brand-icon.png")));// 闈欓粯鍚冩帀 /favicon.ico 鐨?404锛岄伩鍏嶈鍒や负鐧诲綍澶辫触app.get("/favicon.ico", (req, res) => res.status(204).end());// 绂佹娴忚鍣ㄧ紦瀛?admin 闈欐€佽祫婧愶紝閬垮厤婕旂ず鏃朵慨鏀逛笉鐢熸晥app.use("/admin", (req, res, next) => {  res.setHeader("Cache-Control", "no-store, no-cache, must-revalidate, proxy-revalidate");  res.setHeader("Pragma", "no-cache");  res.setHeader("Expires", "0");  next();});app.use("/admin/assets", express.static(path.join(ADMIN_DIR, "assets")));app.get("/admin", (req, res) => res.sendFile(path.join(ADMIN_DIR, "index.html")));app.get("/", (req, res) => res.redirect("/admin"));if (fs.existsSync(CLIENT_DIR)) app.use(express.static(CLIENT_DIR));app.listen(PORT, () => console.log(`MCP Forge admin server running at http://localhost:${PORT}/admin`));